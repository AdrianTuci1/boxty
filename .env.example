# Boxty environment variables
#
# Root `.env` for the current platform layout:
# - `control_plane/` FastAPI control plane
# - worker/provider runtime
# - optional local frontend wiring
#
# Copy to `.env` and fill only the values you actually need.

# -------------------------------------------------------------------
# 1. Control plane / FastAPI server
# -------------------------------------------------------------------

BOXTY_APP_NAME=boxty-control-plane
BOXTY_ENVIRONMENT=development
BOXTY_API_PREFIX=/v1

# Used by CLIs and worker-side helpers when calling the control plane.
BOXTY_CONTROL_PLANE_URL=http://127.0.0.1:8000

# Scheduler defaults
BOXTY_DEFAULT_PROVIDER_POOL=general
BOXTY_DEFAULT_REGION=eu-central

# -------------------------------------------------------------------
# 2. State store / persistence
# -------------------------------------------------------------------

# `memory` for local dev, `dynamodb-single-table` for persistent deploys.
BOXTY_STATE_STORE=memory

# Required when BOXTY_STATE_STORE=dynamodb-single-table
BOXTY_DYNAMODB_TABLE_NAME=
BOXTY_DYNAMODB_REGION=eu-central-1

# -------------------------------------------------------------------
# 3. Object storage
# -------------------------------------------------------------------

# `filesystem` for local dev, `cloudflare-r2` in production.
BOXTY_OBJECT_STORAGE_PROVIDER=filesystem

# Required when BOXTY_OBJECT_STORAGE_PROVIDER=cloudflare-r2
BOXTY_R2_ACCOUNT_ID=
BOXTY_R2_BUCKET=
BOXTY_R2_ACCESS_KEY_ID=
BOXTY_R2_SECRET_ACCESS_KEY=
BOXTY_R2_PUBLIC_BASE_URL=

# -------------------------------------------------------------------
# 4. Invites / transactional email
# -------------------------------------------------------------------

# `console` logs emails locally, `smtp` sends real invites.
BOXTY_INVITE_EMAIL_PROVIDER=console
BOXTY_INVITE_EMAIL_FROM=noreply@boxty.dev
BOXTY_SECRET_ENCRYPTION_KEY=replace_with_long_random_server_key

# Required when BOXTY_INVITE_EMAIL_PROVIDER=smtp
BOXTY_SMTP_HOST=
BOXTY_SMTP_PORT=587
BOXTY_SMTP_USERNAME=
BOXTY_SMTP_PASSWORD=

# -------------------------------------------------------------------
# 5. Worker runtime / scheduler knobs
# -------------------------------------------------------------------

BOXTY_WORKER_RUNTIME=docker
BOXTY_WORKER_POLL_INTERVAL_SECONDS=5
BOXTY_WORKER_DATA_DIR=/tmp/boxty-worker

# GPU fallback / external providers
BOXTY_RUNPOD_ENABLED=true
BOXTY_RUNPOD_API_BASE=https://api.runpod.io

# -------------------------------------------------------------------
# 6. Billing / pricing defaults
# -------------------------------------------------------------------

BOXTY_BOOTSTRAP_CREDIT_USD=20
BOXTY_CPU_PRICE_PER_VCPU_HOUR_USD=0.08
BOXTY_RAM_PRICE_PER_GB_HOUR_USD=0.012
BOXTY_GPU_PRICE_PER_GPU_HOUR_USD=1.8
BOXTY_STORAGE_PRICE_PER_GB_HOUR_USD=0.0015

# -------------------------------------------------------------------
# 7. Provider / worker secrets (only where relevant)
# -------------------------------------------------------------------

BOXTY_PROVIDER_TOKEN=
BOXTY_NODE_KEY=
BOXTY_PROVIDER_POOL=general
BOXTY_PROVIDER_REGION=eu-central
BOXTY_ALLOW_PUBLIC_SSH=false
BOXTY_PROVIDER_HEARTBEAT_TTL_SECONDS=90
BOXTY_ASSIGNMENT_LEASE_TTL_SECONDS=120

# -------------------------------------------------------------------
# 8. Frontend notes
# -------------------------------------------------------------------

# Product UI env lives in `web/.env.example`.
# Example local override:
# VITE_API_BASE=http://127.0.0.1:8000
# VITE_DEV_SKIP_AUTH=true
