BOXTY_ENVIRONMENT=production
BOXTY_APP_NAME=boxty-control-plane
BOXTY_DEFAULT_PROVIDER_POOL={{ boxty_provider_pool | default('general') }}
BOXTY_DEFAULT_REGION={{ boxty_region | default('eu-central') }}
BOXTY_BOOTSTRAP_CREDIT_USD=20

# Persistent storage: Cloudflare R2 / object storage
BOXTY_OBJECT_STORAGE_PROVIDER=cloudflare-r2
BOXTY_R2_ACCOUNT_ID={{ boxty_r2_account_id }}
BOXTY_R2_BUCKET={{ boxty_r2_bucket }}
BOXTY_R2_ACCESS_KEY_ID={{ boxty_r2_access_key_id }}
BOXTY_R2_SECRET_ACCESS_KEY={{ boxty_r2_secret_access_key }}
BOXTY_R2_PUBLIC_BASE_URL={{ boxty_r2_public_base_url }}

# Persistence model
BOXTY_STATE_STORE=dynamodb-single-table
BOXTY_DYNAMODB_TABLE_NAME={{ boxty_dynamodb_table_name }}
BOXTY_DYNAMODB_REGION={{ boxty_dynamodb_region | default('eu-central-1') }}

# Invites
BOXTY_INVITE_EMAIL_PROVIDER={{ boxty_invite_email_provider | default('smtp') }}
BOXTY_INVITE_EMAIL_FROM={{ boxty_invite_email_from }}
{% if boxty_smtp_host is defined %}
BOXTY_SMTP_HOST={{ boxty_smtp_host }}
{% endif %}
{% if boxty_smtp_port is defined %}
BOXTY_SMTP_PORT={{ boxty_smtp_port }}
{% endif %}
{% if boxty_smtp_username is defined %}
BOXTY_SMTP_USERNAME={{ boxty_smtp_username }}
{% endif %}
{% if boxty_smtp_password is defined %}
BOXTY_SMTP_PASSWORD={{ boxty_smtp_password }}
{% endif %}

# GPU fallback
BOXTY_RUNPOD_ENABLED={{ (boxty_runpod_enabled | default(true)) | ternary('true', 'false') }}
{% if boxty_runpod_api_key is defined %}
BOXTY_RUNPOD_API_KEY={{ boxty_runpod_api_key }}
{% endif %}
