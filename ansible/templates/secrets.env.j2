# Boxty Worker Secrets — injected by Ansible
# DO NOT commit this file to git

BOXTY_CONTROL_PLANE_URL={{ boxty_control_plane_url }}
BOXTY_PROVIDER_TOKEN={{ boxty_provider_token }}
BOXTY_NODE_KEY={{ boxty_node_key }}
{% if boxty_llm_api_key is defined %}
LLM_API_KEY={{ boxty_llm_api_key }}
{% endif %}

BOXTY_PROVIDER_POOL={{ boxty_provider_pool | default('general') }}
BOXTY_ALLOW_PUBLIC_SSH={{ (boxty_allow_public_ssh | default(false)) | ternary('true', 'false') }}
BOXTY_RUNPOD_ENABLED={{ (boxty_runpod_enabled | default(true)) | ternary('true', 'false') }}
{% if boxty_runpod_api_key is defined %}
BOXTY_RUNPOD_API_KEY={{ boxty_runpod_api_key }}
{% endif %}
{% if boxty_runpod_default_template is defined %}
BOXTY_RUNPOD_DEFAULT_TEMPLATE={{ boxty_runpod_default_template }}
{% endif %}
{% if boxty_r2_account_id is defined %}
BOXTY_R2_ACCOUNT_ID={{ boxty_r2_account_id }}
{% endif %}
{% if boxty_r2_bucket is defined %}
BOXTY_R2_BUCKET={{ boxty_r2_bucket }}
{% endif %}
{% if boxty_r2_access_key_id is defined %}
BOXTY_R2_ACCESS_KEY_ID={{ boxty_r2_access_key_id }}
{% endif %}
{% if boxty_r2_secret_access_key is defined %}
BOXTY_R2_SECRET_ACCESS_KEY={{ boxty_r2_secret_access_key }}
{% endif %}
{% if boxty_r2_public_base_url is defined %}
BOXTY_R2_PUBLIC_BASE_URL={{ boxty_r2_public_base_url }}
{% endif %}
{% if platform_fee_bps is defined %}
PLATFORM_FEE_BPS={{ platform_fee_bps }}
{% endif %}
{% if boxty_provider_region is defined %}
BOXTY_PROVIDER_REGION={{ boxty_provider_region }}
{% endif %}
