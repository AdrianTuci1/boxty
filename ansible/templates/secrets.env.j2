# Boxty Worker Secrets — injected by Ansible
# DO NOT commit this file to git

BOXTY_CONTROL_PLANE_URL={{ boxty_control_plane_url | default(lookup('env', 'BOXTY_CONTROL_PLANE_URL')) | default('https://control.boxty.dev') }}
BOXTY_PROVIDER_TOKEN={{ boxty_provider_token | default(lookup('env', 'BOXTY_PROVIDER_SHARED_TOKEN')) }}
BOXTY_NODE_KEY={{ boxty_node_key | default(lookup('env', 'BOXTY_NODE_KEY')) }}
{% if boxty_llm_api_key is defined or lookup('env', 'BOXTY_LLM_API_KEY') %}
LLM_API_KEY={{ boxty_llm_api_key | default(lookup('env', 'BOXTY_LLM_API_KEY')) }}
{% endif %}

BOXTY_PROVIDER_POOL={{ boxty_provider_pool | default('general') }}
BOXTY_ALLOW_PUBLIC_SSH={{ (boxty_allow_public_ssh | default(false)) | ternary('true', 'false') }}
BOXTY_RUNPOD_ENABLED={{ (boxty_runpod_enabled | default(true)) | ternary('true', 'false') }}
{% if boxty_runpod_api_key is defined or lookup('env', 'BOXTY_RUNPOD_API_KEY') %}
BOXTY_RUNPOD_API_KEY={{ boxty_runpod_api_key | default(lookup('env', 'BOXTY_RUNPOD_API_KEY')) }}
{% endif %}
{% if boxty_runpod_default_template is defined or lookup('env', 'BOXTY_RUNPOD_DEFAULT_TEMPLATE') %}
BOXTY_RUNPOD_DEFAULT_TEMPLATE={{ boxty_runpod_default_template | default(lookup('env', 'BOXTY_RUNPOD_DEFAULT_TEMPLATE')) }}
{% endif %}
{% if boxty_r2_account_id is defined or lookup('env', 'BOXTY_R2_ACCOUNT_ID') %}
BOXTY_R2_ACCOUNT_ID={{ boxty_r2_account_id | default(lookup('env', 'BOXTY_R2_ACCOUNT_ID')) }}
{% endif %}
{% if boxty_r2_bucket is defined or lookup('env', 'BOXTY_R2_BUCKET') %}
BOXTY_R2_BUCKET={{ boxty_r2_bucket | default(lookup('env', 'BOXTY_R2_BUCKET')) }}
{% endif %}
{% if boxty_r2_access_key_id is defined or lookup('env', 'BOXTY_R2_ACCESS_KEY_ID') %}
BOXTY_R2_ACCESS_KEY_ID={{ boxty_r2_access_key_id | default(lookup('env', 'BOXTY_R2_ACCESS_KEY_ID')) }}
{% endif %}
{% if boxty_r2_secret_access_key is defined or lookup('env', 'BOXTY_R2_SECRET_ACCESS_KEY') %}
BOXTY_R2_SECRET_ACCESS_KEY={{ boxty_r2_secret_access_key | default(lookup('env', 'BOXTY_R2_SECRET_ACCESS_KEY')) }}
{% endif %}
{% if boxty_r2_public_base_url is defined or lookup('env', 'BOXTY_R2_PUBLIC_BASE_URL') %}
BOXTY_R2_PUBLIC_BASE_URL={{ boxty_r2_public_base_url | default(lookup('env', 'BOXTY_R2_PUBLIC_BASE_URL')) }}
{% endif %}
{% if platform_fee_bps is defined %}
PLATFORM_FEE_BPS={{ platform_fee_bps }}
{% endif %}
{% if boxty_provider_region is defined %}
BOXTY_PROVIDER_REGION={{ boxty_provider_region }}
{% endif %}

# Gateway local port (0 = disabled, tunneled only)
BOXTY_GATEWAY_PORT={{ boxty_gateway_port | default(0) }}
