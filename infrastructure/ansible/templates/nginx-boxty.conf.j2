server {
    listen 80;
    listen [::]:80;
    server_name {{ boxty_control_plane_fqdn | default('control.boxty.dev') }};

    location / {
        return 301 https://$server_name$request_uri;
    }
}

server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name {{ boxty_control_plane_fqdn | default('control.boxty.dev') }};

    client_max_body_size 512M;

    location / {
        proxy_pass http://127.0.0.1:8000;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_read_timeout 86400;
    }
}

# Wildcard server block for function endpoints.
# Matches <workspace>-<app>-<function>.boxty.dev and forwards to control plane.
# The control plane resolves the Host header to the actual function instance.
server {
    listen 80;
    listen [::]:80;
    server_name ~^(?<subdomain>.+)\.{{ boxty_domain | default('boxty.dev') | regex_escape }}$;

    location / {
        return 301 https://$server_name$request_uri;
    }
}

server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name ~^(?<subdomain>.+)\.{{ boxty_domain | default('boxty.dev') | regex_escape }}$;

    client_max_body_size 512M;

    location / {
        proxy_pass http://127.0.0.1:8000;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Boxty-Subdomain $subdomain;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_read_timeout 86400;
    }
}
