BOXTY_ENVIRONMENT=production
BOXTY_APP_NAME=boxty-control-plane
BOXTY_DEFAULT_PROVIDER_POOL={{ boxty_provider_pool | default('general') }}
BOXTY_DEFAULT_REGION={{ boxty_region | default('eu-central') }}
BOXTY_BOOTSTRAP_CREDIT_USD=20

# Encryption
BOXTY_SECRET_ENCRYPTION_KEY={{ boxty_secret_encryption_key | default(lookup('env', 'BOXTY_SECRET_ENCRYPTION_KEY')) }}
BOXTY_PROVIDER_TOKEN={{ boxty_provider_shared_token | default(lookup('env', 'BOXTY_PROVIDER_SHARED_TOKEN')) }}

# Persistent storage: Cloudflare R2 / object storage
BOXTY_OBJECT_STORAGE_PROVIDER=cloudflare-r2
BOXTY_R2_ACCOUNT_ID={{ boxty_r2_account_id | default(lookup('env', 'BOXTY_R2_ACCOUNT_ID')) }}
BOXTY_R2_BUCKET={{ boxty_r2_bucket | default(lookup('env', 'BOXTY_R2_BUCKET')) }}
BOXTY_R2_ACCESS_KEY_ID={{ boxty_r2_access_key_id | default(lookup('env', 'BOXTY_R2_ACCESS_KEY_ID')) }}
BOXTY_R2_SECRET_ACCESS_KEY={{ boxty_r2_secret_access_key | default(lookup('env', 'BOXTY_R2_SECRET_ACCESS_KEY')) }}
BOXTY_R2_PUBLIC_BASE_URL={{ boxty_r2_public_base_url | default(lookup('env', 'BOXTY_R2_PUBLIC_BASE_URL')) }}

# Persistence model
BOXTY_STATE_STORE=dynamodb-single-table
BOXTY_DYNAMODB_TABLE_NAME={{ boxty_dynamodb_table_name | default(lookup('env', 'BOXTY_DYNAMODB_TABLE_NAME')) }}
BOXTY_DYNAMODB_REGION={{ boxty_dynamodb_region | default(lookup('env', 'BOXTY_DYNAMODB_REGION')) | default('eu-central-1') }}

# Invites
BOXTY_INVITE_EMAIL_PROVIDER={{ boxty_invite_email_provider | default('smtp') }}
BOXTY_INVITE_EMAIL_FROM={{ boxty_invite_email_from | default(lookup('env', 'BOXTY_INVITE_EMAIL_FROM')) }}
{% if boxty_smtp_host is defined or lookup('env', 'BOXTY_SMTP_HOST') %}
BOXTY_SMTP_HOST={{ boxty_smtp_host | default(lookup('env', 'BOXTY_SMTP_HOST')) }}
{% endif %}
{% if boxty_smtp_port is defined or lookup('env', 'BOXTY_SMTP_PORT') %}
BOXTY_SMTP_PORT={{ boxty_smtp_port | default(lookup('env', 'BOXTY_SMTP_PORT')) | default('587') }}
{% endif %}
{% if boxty_smtp_username is defined or lookup('env', 'BOXTY_SMTP_USERNAME') %}
BOXTY_SMTP_USERNAME={{ boxty_smtp_username | default(lookup('env', 'BOXTY_SMTP_USERNAME')) }}
{% endif %}
{% if boxty_smtp_password is defined or lookup('env', 'BOXTY_SMTP_PASSWORD') %}
BOXTY_SMTP_PASSWORD={{ boxty_smtp_password | default(lookup('env', 'BOXTY_SMTP_PASSWORD')) }}
{% endif %}

# GPU fallback
BOXTY_RUNPOD_ENABLED={{ (boxty_runpod_enabled | default(true)) | ternary('true', 'false') }}
{% if boxty_runpod_api_key is defined or lookup('env', 'BOXTY_RUNPOD_API_KEY') %}
BOXTY_RUNPOD_API_KEY={{ boxty_runpod_api_key | default(lookup('env', 'BOXTY_RUNPOD_API_KEY')) }}
{% endif %}

# OAuth providers
{% if boxty_google_client_id is defined or lookup('env', 'BOXTY_GOOGLE_CLIENT_ID') %}
BOXTY_GOOGLE_CLIENT_ID={{ boxty_google_client_id | default(lookup('env', 'BOXTY_GOOGLE_CLIENT_ID')) }}
{% endif %}
{% if boxty_google_client_secret is defined or lookup('env', 'BOXTY_GOOGLE_CLIENT_SECRET') %}
BOXTY_GOOGLE_CLIENT_SECRET={{ boxty_google_client_secret | default(lookup('env', 'BOXTY_GOOGLE_CLIENT_SECRET')) }}
{% endif %}
{% if boxty_google_redirect_uri is defined or lookup('env', 'BOXTY_GOOGLE_REDIRECT_URI') %}
BOXTY_GOOGLE_REDIRECT_URI={{ boxty_google_redirect_uri | default(lookup('env', 'BOXTY_GOOGLE_REDIRECT_URI')) }}
{% endif %}
{% if boxty_github_client_id is defined or lookup('env', 'BOXTY_GITHUB_CLIENT_ID') %}
BOXTY_GITHUB_CLIENT_ID={{ boxty_github_client_id | default(lookup('env', 'BOXTY_GITHUB_CLIENT_ID')) }}
{% endif %}
{% if boxty_github_client_secret is defined or lookup('env', 'BOXTY_GITHUB_CLIENT_SECRET') %}
BOXTY_GITHUB_CLIENT_SECRET={{ boxty_github_client_secret | default(lookup('env', 'BOXTY_GITHUB_CLIENT_SECRET')) }}
{% endif %}
{% if boxty_github_redirect_uri is defined or lookup('env', 'BOXTY_GITHUB_REDIRECT_URI') %}
BOXTY_GITHUB_REDIRECT_URI={{ boxty_github_redirect_uri | default(lookup('env', 'BOXTY_GITHUB_REDIRECT_URI')) }}
{% endif %}
