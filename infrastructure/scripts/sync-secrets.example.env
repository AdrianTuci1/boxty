# Copy this file to .env, fill in your real values, then run:
#   ./infrastructure/scripts/sync-secrets.sh
#
# WARNING: Never commit .env to git.

# Terraform / AWS
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...

# Cloudflare
CLOUDFLARE_API_TOKEN=...
CLOUDFLARE_ACCOUNT_ID=...
CLOUDFLARE_ZONE_ID=...

# R2 (used by control plane and workers)
R2_ACCESS_KEY_ID=...
R2_SECRET_ACCESS_KEY=...
R2_ENDPOINT_URL=https://<account-id>.r2.cloudflarestorage.com
R2_BUCKET=boxty
R2_PUBLIC_BASE_URL=https://cli.boxty.dev

# SSH keys for Ansible deployment (paste full private key content)
CONTROL_PLANE_SSH_KEY=***
WORKER_SSH_KEY=***

# Control plane
BOXTY_SECRET_ENCRYPTION_KEY=...
BOXTY_PROVIDER_SHARED_TOKEN=...
BOXTY_CONTROL_PLANE_URL=https://control.boxty.dev
BOXTY_DYNAMODB_TABLE_NAME=boxty-control-plane
BOXTY_DYNAMODB_REGION=eu-central-1
BOXTY_R2_ACCOUNT_ID=...
BOXTY_R2_BUCKET=boxty
BOXTY_R2_ACCESS_KEY_ID=...
BOXTY_R2_SECRET_ACCESS_KEY=...
BOXTY_R2_PUBLIC_BASE_URL=https://cli.boxty.dev

# Optional integrations
BOXTY_RUNPOD_API_KEY=...
BOXTY_RUNPOD_DEFAULT_TEMPLATE=gpu-inference

# OAuth providers (credentials are created manually in Google Cloud Console / GitHub OAuth App settings)
BOXTY_GOOGLE_CLIENT_ID=...
BOXTY_GOOGLE_CLIENT_SECRET=...
BOXTY_GOOGLE_REDIRECT_URI=https://app.boxty.dev/oauth/callback
BOXTY_GITHUB_CLIENT_ID=...
BOXTY_GITHUB_CLIENT_SECRET=...
BOXTY_GITHUB_REDIRECT_URI=https://app.boxty.dev/oauth/callback

# CLI download base URL
CLI_BASE_URL=https://cli.boxty.dev

# Web environment variables (production)
BOXTY_SMTP_HOST=smtp.resend.com
BOXTY_SMTP_PORT=587
BOXTY_SMTP_USERNAME=resend
BOXTY_SMTP_PASSWORD=...
BOXTY_INVITE_EMAIL_FROM=noreply@boxty.dev

# Web environment variables (production)
VITE_API_BASE_PRODUCTION=https://control.boxty.dev
VITE_DEMO_MODE_PRODUCTION=false
VITE_STRIPE_PUBLIC_KEY=pk_live_...
VITE_POSTHOG_KEY=phc_...
VITE_SENTRY_DSN=https://...@....ingest.sentry.io/...

# Web environment variables (staging)
VITE_API_BASE_STAGING=https://control-staging.boxty.dev
VITE_DEMO_MODE_STAGING=true
VITE_STRIPE_PUBLIC_KEY=pk_test_...
VITE_POSTHOG_KEY=phc_...
VITE_SENTRY_DSN=https://...@....ingest.sentry.io/...

# Package publishing
PYPI_API_TOKEN=pypi-...
NPM_TOKEN=npm_...

# Cloudflare Pages project name
CLOUDFLARE_PAGES_PROJECT=boxty-web
