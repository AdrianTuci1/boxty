{
  "name": "@boxty/sdk",
  "version": "1.0.0",
  "description": "Boxty SDK — interact with secrets, volumes, databases, and app state from your Boxty workloads",
  "license": "MIT",
  "author": "Adrian Tucicovenco",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "devDependencies": {
    "typescript": "^5.7",
    "@types/node": "^22"
  },
  "scripts": {
    "build": "tsc && node scripts/build-cjs.mjs",
    "prepublishOnly": "npm run build"
  },
  "keywords": ["boxty", "p2p", "serverless", "agents"],
  "repository": {
    "type": "git",
    "url": "https://github.com/adriantucicovenco/boxty"
  }
}
