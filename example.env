# ═══════════════════════════════════════════════════════════
# Boxty CI/CD Secrets — populate these in GitHub Settings
# ═══════════════════════════════════════════════════════════
#
# Go to: GitHub Repo → Settings → Secrets and variables → Actions → New repository secret
# Paste each value below as a secret.
#
# OR use the CLI script:
#   ./scripts/setup-secrets.sh
#
# ═══════════════════════════════════════════════════════════
# 1. PYPI — Python SDK Publishing
# ═══════════════════════════════════════════════════════════
# Generate at: https://pypi.org/manage/account/token/
# Scopes needed: "Upload packages" for project "boxty"
PYPI_API_TOKEN=pypi-AgEIcHlwaS5vcmcCJGNh...n

# ═══════════════════════════════════════════════════════════
# 2. NPM — JavaScript SDK Publishing
# ═══════════════════════════════════════════════════════════
# Generate at: https://www.npmjs.com/settings/tokens
# Scopes needed: "Publish"
NPM_TOKEN=npm_xxxxx...n

# ═══════════════════════════════════════════════════════════
# 3. CLOUDFLARE — Pages Deploy + R2 Storage
# ═══════════════════════════════════════════════════════════
# API Token: https://dash.cloudflare.com/profile/api-tokens
#   Template: "Edit Cloudflare Workers" + "Cloudflare Pages:Edit"
#   OR custom: zone:read, page:edit, account:read
#
# Account ID: https://dash.cloudflare.com/ → right sidebar
# Pages Project: name of your Cloudflare Pages project (e.g., "boxty")
CLOUDFLARE_API_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLOUDFLARE_ACCOUNT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLOUDFLARE_PAGES_PROJECT=boxty

# R2 (S3-compatible storage for CLI binaries)
# Create bucket at: https://dash.cloudflare.com/ → R2
# Create API token: R2 → Manage API Tokens → Create API Token
R2_ACCESS_KEY_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
R2_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
R2_ENDPOINT_URL=https://xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.r2.cloudflarestorage.com
R2_BUCKET=boxty-cli

# ═══════════════════════════════════════════════════════════
# 4. ANSIBLE / VPS WORKER DEPLOYMENT
# ═══════════════════════════════════════════════════════════
# SSH private key for accessing worker VPS nodes
# Generate: ssh-keygen -t ed25519 -f ~/.ssh/boxty_workers -C "boxty-workers"
# Add public key to each VPS: ~/.ssh/authorized_keys
VPS_SSH_KEY=-----BEGIN OPENSSH PRIVATE KEY-----
...
-----END OPENSSH PRIVATE KEY-----

# Optional: Ansible Vault password for encrypting sensitive vars
ANSIBLE_VAULT_PASSWORD=optional-strong-password-here

# ═══════════════════════════════════════════════════════════
# 5. GITHUB — Auto-generated (no need to set manually)
# ═══════════════════════════════════════════════════════════
# GITHUB_TOKEN is automatically provided by GitHub Actions
# DO NOT add this as a secret — it's built-in
# GITHUB_TOKEN=ghs_xxxxxxxxxxxxxxxxxxxx

# ═══════════════════════════════════════════════════════════
# 6. OPTIONAL — Environment Protection (manual approval)
# ═══════════════════════════════════════════════════════════
# Configure in GitHub: Settings → Environments → New environment
# Create environments: "pypi", "npm"
# Add yourself as required reviewer for each
# This ensures publish only happens after manual approval
